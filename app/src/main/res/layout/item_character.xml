<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    style="@style/ModernCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Rank Number -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp">
            <TextView
                android:id="@+id/tvRank"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="1"
                android:textColor="@color/colorAccent"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:background="@drawable/circle_bg"
                android:backgroundTint="@color/colorCardDark"/>
        </FrameLayout>

        <!-- Anime Poster Image -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="54dp"
            android:layout_height="76dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            android:layout_marginEnd="12dp">
            <ImageView
                android:id="@+id/ivPoster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/image_bg"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Title, Type, Progress, Votes -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anime Title"
                android:textColor="@color/colorTextPrimary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.02"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TV Series"
                android:textColor="@color/colorTextMuted"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <!-- Magenta Progress Bar -->
            <ProgressBar
                android:id="@+id/progressVotes"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:progress="40"
                android:max="100"
                android:progressTint="@color/colorPrimary"
                android:progressBackgroundTint="@color/colorCardDark"/>

            <TextView
                android:id="@+id/tvVotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 votes"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

        </LinearLayout>

        <!-- Heart Vote Button -->
        <ImageButton
            android:id="@+id/btnVote"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_heart_outline"
            app:tint="@color/colorAccent"
            android:layout_marginStart="8dp"
            android:contentDescription="Vote"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>