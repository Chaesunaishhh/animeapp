<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="150dp"
    android:layout_height="220dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1AFFFFFF"
    android:clickable="true"
    android:focusable="true"
    app:rippleColor="#33F72585">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Anime Poster -->
        <ImageView
            android:id="@+id/animeImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Anime Poster" />

        <!-- Gradient Overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/anime_card_gradient" />

        <!-- Rating Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="8dp"
            android:background="@drawable/chip_bg"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/animeScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ 85"
                android:textColor="@color/colorWhite"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- In-Watchlist Badge -->
        <TextView
            android:id="@+id/badgeInWatchlist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="8dp"
            android:background="@drawable/chip_bg"
            android:backgroundTint="#F72585"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="IN LIST"
            android:textColor="@color/colorWhite"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Add Button -->
        <ImageButton
            android:id="@+id/btnWishlist"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:background="@drawable/circle_background"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_add"
            app:tint="@color/colorWhite" />

        <!-- Bottom Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/animeTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:layout_marginEnd="32dp"
                android:text="Anime Title"
                android:textColor="@color/colorWhite"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="start" />

        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
