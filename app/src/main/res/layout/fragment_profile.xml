<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/colorBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Profile Header -->
        <TextView
            android:text="Profile"
            android:textSize="22sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <ImageView
                android:id="@+id/profileImage"
                android:src="@drawable/ic_profile_placeholder"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:scaleType="centerCrop"
                android:background="@drawable/circle_background"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/profileUsername"
                    android:text="Username"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/profileEmail"
                    android:text="gmail.com"
                    android:textSize="14sp"
                    android:textColor="@color/colorGray"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Edit Profile -->
        <Button
            android:id="@+id/editProfileButton"
            android:text="EDIT PROFILE"
            android:background="@drawable/rounded_button"
            android:textColor="@color/colorWhite"
            android:textAllCaps="true"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Statistics Section -->
        <TextView
            android:text="📊 Your Statistics"
            android:textColor="@color/colorWhite"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginTop="12dp">

            <!-- Total Watched -->

            <!-- In Watchlist -->
            <LinearLayout
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:layout_row="0"
                android:layout_column="0"
                android:layout_margin="8dp"
                android:background="@drawable/stat_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/statWatched"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Anime Watched: 0"
                    android:textColor="@color/colorWhite"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@drawable/stat_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvInWatchlist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="In Watchlist: 0"
                    android:textColor="@color/colorWhite"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Quizzes Taken -->
            <LinearLayout
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@drawable/stat_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvQuizzesTaken"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quizzes Taken: 0"
                    android:textColor="@color/colorWhite"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Quiz Avg Score -->
            <LinearLayout
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@drawable/stat_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvQuizAvgScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quiz Avg Score: 0%"
                    android:textColor="@color/colorWhite"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </GridLayout>

        <TextView
            android:text="🏆 Achievements"
            android:textColor="@color/colorWhite"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <GridLayout
            android:id="@+id/achievementsGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginTop="12dp">

            <!-- Collector -->
            <LinearLayout
                android:id="@+id/collectorCard"
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:layout_margin="8dp"
                android:background="@drawable/achievement_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Collector"
                    android:textColor="@color/colorWhite"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add 10 anime to your watchlist"
                    android:textColor="@color/colorGray"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/progressCollector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress: 0/10"
                    android:textColor="@color/colorAccent"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:ellipsize="none"/>
            </LinearLayout>

            <!-- Master Collector -->
            <LinearLayout
                android:id="@+id/masterCollectorCard"
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:layout_margin="8dp"
                android:background="@drawable/achievement_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Master Collector"
                    android:textColor="@color/colorWhite"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add 30 anime to your watchlist"
                    android:textColor="@color/colorGray"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/progressMasterCollector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress: 0/30"
                    android:textColor="@color/colorAccent"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:ellipsize="none"/>
            </LinearLayout>

            <!-- Finisher -->
            <LinearLayout
                android:id="@+id/finisherCard"
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:layout_margin="8dp"
                android:background="@drawable/achievement_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Finisher"
                    android:textColor="@color/colorWhite"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complete 5 anime series"
                    android:textColor="@color/colorGray"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/progressFinisher"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress: 0/5"
                    android:textColor="@color/colorAccent"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:ellipsize="none"/>
            </LinearLayout>

            <!-- Master Finisher -->
            <LinearLayout
                android:id="@+id/masterFinisherCard"
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:layout_margin="8dp"
                android:background="@drawable/achievement_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Master Finisher"
                    android:textColor="@color/colorWhite"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complete 20 anime series"
                    android:textColor="@color/colorGray"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/progressMasterFinisher"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress: 0/20"
                    android:textColor="@color/colorAccent"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:ellipsize="none"/>
            </LinearLayout>

            <!-- Legendary Otaku -->
            <LinearLayout
                android:id="@+id/legendaryOtakuCard"
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:layout_margin="8dp"
                android:background="@drawable/achievement_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Legendary Otaku"
                    android:textColor="@color/colorWhite"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complete 50 anime series"
                    android:textColor="@color/colorGray"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/progressLegendaryOtaku"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress: 0/50"
                    android:textColor="@color/colorAccent"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:ellipsize="none"/>
            </LinearLayout>

            <!-- Quiz Enthusiast -->
            <LinearLayout
                android:id="@+id/quizEnthusiastCard"
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:layout_margin="8dp"
                android:background="@drawable/achievement_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quiz Enthusiast"
                    android:textColor="@color/colorWhite"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complete 10 quizzes"
                    android:textColor="@color/colorGray"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/progressQuizEnthusiast"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress: 0/10"
                    android:textColor="@color/colorAccent"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:ellipsize="none"/>
            </LinearLayout>
        </GridLayout>


        <!-- Settings Section -->
        <TextView
            android:text="⚙️ Settings"
            android:textColor="@color/colorWhite"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="40dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnNotifications"
                android:text="Notifications"
                android:backgroundTint="@color/darkGray"
                android:textColor="@color/colorWhite"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnGeneralSettings"
                android:text="General Settings"
                android:backgroundTint="@color/darkGray"
                android:textColor="@color/colorWhite"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnHelpSupport"
                android:text="Help and Support"
                android:backgroundTint="@color/darkGray"
                android:textColor="@color/colorWhite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Logout -->
        <Button
            android:id="@+id/logoutButton"
            android:text="LOGOUT"
            android:backgroundTint="@color/colorRed"
            android:textColor="@color/colorWhite"
            android:textAllCaps="true"
            android:layout_marginTop="40dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>
