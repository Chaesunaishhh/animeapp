<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Loading Overlay -->
        <ProgressBar
            android:id="@+id/profileProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="20dp"
            android:indeterminateTint="@color/colorAccent"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Header Banner -->
        <View
            android:id="@+id/headerBackground"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/gradient_primary_accent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/gradient_scrim_bottom"
            app:layout_constraintBottom_toBottomOf="@+id/headerBackground" />

        <!-- Profile Picture & Identity -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/profileImageCard"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="150dp"
            app:cardCornerRadius="55dp"
            app:cardElevation="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="@color/colorBackground"
            app:strokeWidth="4dp">

            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile_placeholder" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/profileUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-black"
            android:text=""
            android:textColor="@color/colorWhite"
            android:textSize="28sp"
            android:letterSpacing="0.02"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/profileImageCard" />

        <TextView
            android:id="@+id/profileEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text=""
            android:textColor="@color/colorTextSecondary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/profileUsername" />

        <!-- Edit Profile Button - Floating Style -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditProfileRow"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EDIT PROFILE"
            android:textColor="@color/colorAccent"
            android:textSize="12sp"
            android:fontFamily="sans-serif-black"
            app:icon="@drawable/ic_edit"
            app:iconSize="16dp"
            app:iconTint="@color/colorAccent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/profileEmail" />

        <!-- Stats Dashboard -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/statsCard"
            style="@style/ModernCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@+id/btnEditProfileRow">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/statWatched"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="--"
                        android:textColor="@color/colorAccent"
                        android:textSize="22sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="WATCHED"
                        android:textColor="@color/colorTextMuted"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="30dp" android:layout_gravity="center_vertical" android:background="@color/dividerColor"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvInWatchlist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="--"
                        android:textColor="@color/colorSimpleBlue"
                        android:textSize="22sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="PLANNING"
                        android:textColor="@color/colorTextMuted"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="30dp" android:layout_gravity="center_vertical" android:background="@color/dividerColor"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvQuizzesTaken"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="--"
                        android:textColor="@color/colorAccent"
                        android:textSize="22sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="QUIZZES"
                        android:textColor="@color/colorTextMuted"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="30dp" android:layout_gravity="center_vertical" android:background="@color/dividerColor"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvQuizAvgScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="--"
                        android:textColor="@color/colorSimpleGreen"
                        android:textSize="22sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="AVG SCORE"
                        android:textColor="@color/colorTextMuted"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Achievements Section -->
        <TextView
            android:id="@+id/labelTrophy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-black"
            android:text="ACHIEVEMENTS"
            android:textColor="@color/colorTextPrimary"
            android:textSize="16sp"
            android:letterSpacing="0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/statsCard" />

        <HorizontalScrollView
            android:id="@+id/trophyScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@+id/labelTrophy">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Achievement Card Template -->
                <include layout="@layout/item_achievement_profile" android:id="@+id/badge1"/>
                <include layout="@layout/item_achievement_profile" android:id="@+id/badge2"/>
                <include layout="@layout/item_achievement_profile" android:id="@+id/badge3"/>
                <include layout="@layout/item_achievement_profile" android:id="@+id/badge4"/>
                <include layout="@layout/item_achievement_profile" android:id="@+id/badge5"/>
                <include layout="@layout/item_achievement_profile" android:id="@+id/badge6"/>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Menu Section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuCard"
            style="@style/ModernCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@+id/trophyScroll">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <include layout="@layout/item_profile_menu" android:id="@+id/itemNotif"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/dividerColor" android:layout_marginHorizontal="16dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:paddingHorizontal="16dp">
                    <ImageView
                        android:id="@+id/iconDark"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_moon"
                        app:tint="@color/colorSimpleBlue" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:layout_toEndOf="@id/iconDark"
                        android:text="Midnight Mode"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="16sp" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        app:thumbTint="@color/colorSimpleBlue"
                        app:trackTint="@color/colorSimpleBlue" />
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/dividerColor" android:layout_marginHorizontal="16dp"/>
                <include layout="@layout/item_profile_menu" android:id="@+id/itemHelp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/logoutButton"
            style="@style/ModernButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="40dp"
            android:text="LOGOUT"
            android:textColor="@color/colorWhite"
            android:backgroundTint="@color/colorError"
            app:layout_constraintTop_toBottomOf="@+id/menuCard"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
