<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:strokeWidth="1dp"
    app:strokeColor="#20FFFFFF">

    <LinearLayout
        android:orientation="horizontal"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Thumbnail -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/animeImage"
            android:layout_width="100dp"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:contentDescription="@string/anime_image_desc"
            app:shapeAppearanceOverlay="@style/RoundedImage"/>

        <!-- Info Column -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <!-- Title -->
            <TextView
                android:id="@+id/animeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/anime_title"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- Rating + Extra Info -->
            <TextView
                android:id="@+id/animeScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/anime_info"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="28dp"/>

<!--            &lt;!&ndash; Status Badge &ndash;&gt;-->
<!--            <TextView-->
<!--                android:id="@+id/animeStatus"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="@string/anime_completed"-->
<!--                android:textColor="#4CAF50"-->
<!--                android:textSize="12sp"-->
<!--                android:layout_marginTop="6dp"/>-->

            <!-- Action Buttons -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

<!--                <Button-->
<!--                    android:id="@+id/markCompleteButton"-->
<!--                    android:text="Mark Complete"-->
<!--                    android:textColor="@color/colorWhite"-->
<!--                    android:background="@drawable/rounded_button"-->
<!--                    android:layout_width="0dp"-->
<!--                    android:layout_weight="1"-->
<!--                    android:layout_height="48dp"/>-->

                <!--                <ImageButton-->
<!--                    android:id="@+id/deleteButton"-->
<!--                    android:src="@drawable/ic_delete"-->
<!--                    android:background="@drawable/circle_button"-->
<!--                    app:tint="@color/colorWhite"-->
<!--                    android:layout_width="48dp"-->
<!--                    android:layout_height="48dp"-->
<!--                    android:layout_marginStart="12dp"-->
<!--                    android:contentDescription="@string/delete_button_desc" />-->

                <Button
                    android:id="@+id/markCompleteButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button"
                    android:ellipsize="end"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:singleLine="true"
                    android:text="COMPLETE"
                    android:textColor="@color/colorWhite" />

                <ImageButton
                    android:id="@+id/deleteButton"
                    android:src="@drawable/ic_delete"
                    android:background="@drawable/circle_button"
                    app:tint="@color/colorWhite"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="12dp"
                    android:contentDescription="@string/delete_button_desc"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
