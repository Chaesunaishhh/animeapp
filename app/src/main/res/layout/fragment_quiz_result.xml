<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#0F0F1A"
    android:padding="24dp"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Trophy Icon -->
    <ImageView
        android:id="@+id/imgTrophy"
        android:src="@drawable/ic_trophy"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:contentDescription="Trophy"
        android:tint="#FF4081"
        android:layout_marginBottom="16dp"/>

    <!-- Title -->
    <TextView
        android:id="@+id/tvResultTitle"
        android:text="Quiz Complete!"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvResultSubtitle"
        android:text="Great job on completing the quiz"
        android:textColor="#888888"
        android:textSize="14sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <!-- Score -->
    <TextView
        android:id="@+id/tvFinalScore"
        android:text="5/10"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"/>

    <!-- Percentage -->
    <TextView
        android:id="@+id/tvPercentage"
        android:text="50% Correct"
        android:textColor="#FF4081"
        android:textSize="16sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <!-- Time -->
    <TextView
        android:id="@+id/tvTime"
        android:text="394 seconds"
        android:textColor="#888888"
        android:textSize="14sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"/>

    <!-- Buttons -->
    <Button
        android:id="@+id/btnTryAgain"
        android:text="Try Again"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#FF4081"
        android:textColor="@android:color/white"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnLeaderboard"
        android:text="View Leaderboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#333333"
        android:textColor="@android:color/white"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnDashboard"
        android:text="Back to Dashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#333333"
        android:textColor="@android:color/white"/>
</LinearLayout>
