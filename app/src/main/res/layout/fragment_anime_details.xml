<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#0F0F1A">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Cover Image -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardUseCompatPadding="true">

            <ImageView
                android:id="@+id/animeCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
        </androidx.cardview.widget.CardView>

        <!-- Title + Score -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/animeTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Anime Title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"/>

            <TextView
                android:id="@+id/animeScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ 0"
                android:textSize="16sp"
                android:textColor="#FFD700"/>
        </LinearLayout>

        <!-- Meta Info -->
        <TextView
            android:id="@+id/animeMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2019 • Action, Fantasy • 52 Episodes"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="12dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="12dp"/>

        <!-- Description -->
        <TextView
            android:id="@+id/animeDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Anime description goes here..."
            android:textSize="14sp"
            android:textColor="#CCCCCC"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="20dp"/>

        <!-- Characters Section -->
        <TextView
            android:id="@+id/animeCharactersLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Characters:"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/animeCharacters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textSize="14sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="20dp"/>

        <!-- Action Buttons -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnWatchlist"
                android:text="ADD TO WATCHLIST"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#333333"
                android:textStyle="bold"
                android:textColor="@android:color/white"/>
        </LinearLayout>


        <!-- Watchlist Actions -->
        <LinearLayout
            android:id="@+id/layoutDetailsActions"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">

            <Button
                android:id="@+id/btnDetailsComplete"
                android:text="COMPLETE"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:backgroundTint="@color/colorGray"
                android:textColor="@android:color/white"/>

            <Button
                android:id="@+id/btnDetailsRemove"
                android:text="REMOVE"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:backgroundTint="#F44336"
                android:textColor="@android:color/white"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
