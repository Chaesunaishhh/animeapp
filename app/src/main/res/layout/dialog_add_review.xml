<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="28dp"
    app:cardBackgroundColor="@color/colorBackground"
    app:strokeWidth="1dp"
    app:strokeColor="@color/dividerColor">

    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Share Your Thoughts"
            android:textColor="@color/colorWhite"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your review helps the community"
            android:textColor="@color/colorTextMuted"
            android:textSize="13sp"
            android:layout_marginBottom="24dp"/>

        <!-- Anime Title Selection -->
        <AutoCompleteTextView
            android:id="@+id/editAnimeTitle"
            android:hint="Select Anime..."
            android:textColor="@color/colorWhite"
            android:textColorHint="@color/colorTextMuted"
            android:background="@drawable/edittext"
            android:padding="16dp"
            android:completionThreshold="1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="16dp"/>

        <!-- Premium Rating Interaction -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:orientation="vertical">

            <RatingBar
                android:id="@+id/ratingBar"
                android:numStars="5"
                android:stepSize="1"
                android:progressTint="@color/rating_star"
                android:secondaryProgressTint="@color/rating_star"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to rate"
                android:textColor="@color/colorTextMuted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Review Content -->
        <EditText
            android:id="@+id/editReview"
            android:hint="Write your review here..."
            android:textColor="@color/colorWhite"
            android:textColorHint="@color/colorTextMuted"
            android:background="@drawable/edittext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="140dp"
            android:gravity="top"
            android:padding="16dp"
            android:inputType="textMultiLine"
            android:layout_marginBottom="24dp"/>

        <!-- Buttons -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/OutlinedModernButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="54dp"
                android:text="Discard"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                style="@style/ModernButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="54dp"
                android:text="Post Review"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>